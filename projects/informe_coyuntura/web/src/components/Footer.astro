---
import { informe } from "../lib/datos.ts";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<footer class="cg-foot">
    <div class="cg-foot-inner">
        <div class="cg-foot-brand">
            <span class="cg-nav-logo"><img src={`${base}/logo-cigob.png`} alt="Fundación CiGob" /></span>
            <div>
                <strong>Realidad Política Argentina</strong>
                <span>Un proyecto de Fundación CiGob</span>
            </div>
        </div>
        <div class="cg-foot-cols">
            <div>
                <h4>El observatorio</h4>
                <a href="#snapshot">Mes actual</a>
                <a href="#evolucion">Evolución</a>
                <a href="#archivo">Hemeroteca</a>
                <a href="#metodologia">Metodología</a>
            </div>
            <div>
                <h4>Institucional</h4>
                <a href="https://cigob.org" target="_blank" rel="noopener">cigob.org</a>
                <a href="mailto:info@cigob.org.ar">info@cigob.org.ar</a>
            </div>
            <div>
                <h4>Para investigadores</h4>
                <a href="https://github.com/Juanpintoselso33/biblitotecario-ai" target="_blank" rel="noopener">Repositorio</a>
                <a href="#metodologia">Metodología</a>
                <a href="#archivo">Archivo</a>
                <p style="margin-top:8px;color:#9CA39F;font-size:12.5px;">
                    Buenos Aires · República Argentina
                </p>
            </div>
        </div>
    </div>
    <div class="cg-foot-legal">
        © 2026 Fundación CiGob · Observatorio independiente de indicadores públicos · Datos generados: <span id="cg-foot-time">{informe.generated_at}</span>
    </div>
</footer>
