---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import IndicadorTile from "../components/IndicadorTile.astro";
import IndicadorModal from "../components/IndicadorModal.astro";
import {
  informe, CINTURONES, verdictDeCinturon, indicadoresOrdenados,
  fuentesDeCinturon, cap,
} from "../lib/datos.ts";

export function getStaticPaths() {
  return CINTURONES.map(c => ({ params: { slug: c.slug }, props: { meta: c } }));
}

const { meta } = Astro.props;
const c = informe.cinturones[meta.key];
const verdict = verdictDeCinturon(c.estado);
const verdictLabel = { verde: "Estable", amarillo: "En tensión", rojo: "Crítico" }[verdict];
const filas = indicadoresOrdenados(c);
const fuentes = fuentesDeCinturon(c);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout title={`${meta.nombre} · Observatorio CIGOB`}>
  <Nav />
  <header class={`cg-hero cg-detalle-hero cg-detalle-hero--${meta.slug}`} id="top">
    <div class="cg-hero-inner cg-detalle-inner">
      <p class="cg-eyebrow"><a href={`${base}/`}>← Resumen</a> · Cinturón</p>
      <h1 class="cg-hero-title cg-detalle-title">{meta.nombre}</h1>
      <p class="cg-hero-lead cg-detalle-lead">{meta.sub}.</p>
      <div class="cg-detalle-meta">
        <span class:list={["cg-verdict", verdict]}><span class="cg-verdict-dot"></span>{verdictLabel}</span>
        <span class="cg-detalle-chip">Score <strong>{c.score}/10</strong></span>
        <span class="cg-detalle-chip">Riesgo: <strong>{cap(c.barbarismo_riesgo)}</strong></span>
        <span class="cg-detalle-chip">{filas.length} indicadores</span>
      </div>
    </div>
  </header>
  <main class="cg-main">
    <section class="cg-section">
      <div class="cg-section-head">
        <p class="cg-eyebrow">Indicadores</p>
        <h2 class="cg-h2">El detalle, hoy</h2>
        <p class="cg-h2-sub">Tocá cualquier indicador para ver qué mide, qué aporta y su evolución. Automatizados primero; carga manual y estimaciones al final.</p>
      </div>
      <div class="cg-tile-grid">
        {filas.map(({ key, ind }) => <IndicadorTile ikey={key} ind={ind} slug={meta.slug} />)}
      </div>
    </section>

    <section class="cg-section cg-sources" id="fuentes">
      <p class="cg-eyebrow">Fuentes</p>
      <ul>{fuentes.map(f => <li>{f}</li>)}</ul>
    </section>
  </main>
  <Footer />
  <IndicadorModal />
</Layout>
